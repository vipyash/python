import re
class Solution(object):
    def isMatch(self, s, p):
        """
        :type s: str
        :type p: str
        :rtype: bool
        """
        memo = {}

        def dfs(i,j):
            if (i,j ) in memo:
                return memon([i,j])

            if j == len(p):
                return i == len(s)
            first_match=i < len(s) and (p[j] == s[i] or p[j] == '.')

            if j+1 < len(p) and p[j + 1] == '*':
                memo[(i, j)] = (dfs(i, j + 2) or   (first_match and dfs(i + 1, j)))
                return memo[(i,j)]
            else:
                memo[(i, j)] = first_match and dfs(i + 1, j + 1)
                return memo[(i, j)]

        return dfs(0,0)     
