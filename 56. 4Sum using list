            for a in range(z+1,len(nums)):
                c=nums[i]+nums[j]+nums[z]+nums[a]
                if c == target:
                    quad = sorted([nums[i], nums[j], nums[z], nums[a]])
                    if quad not in results:  # avoid duplicates
                        results.append(quad)

